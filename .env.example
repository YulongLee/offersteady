# Shared app metadata
OFFERSTEADY_APP_NAME=OfferSteady Backend
OFFERSTEADY_APP_VERSION=0.1.0
OFFERSTEADY_ENV=development
OFFERSTEADY_APP_MODE=foundation
OFFERSTEADY_API_PREFIX=/api/v1
OFFERSTEADY_LOG_LEVEL=INFO
OFFERSTEADY_LOG_JSON=true
OFFERSTEADY_REQUEST_ID_HEADER=X-Request-Id
OFFERSTEADY_PUBLIC_WEB_BASE_URL=http://127.0.0.1:5173
OFFERSTEADY_CORS_ALLOWED_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]

# Backend runtime
OFFERSTEADY_DATABASE_URL=postgresql://offersteady:offersteady@127.0.0.1:5432/offersteady
OFFERSTEADY_DATABASE_CONNECT_TIMEOUT_SECONDS=3
OFFERSTEADY_DATABASE_APPLICATION_NAME=offersteady-backend
OFFERSTEADY_PGVECTOR_SCHEMA=public
OFFERSTEADY_PGVECTOR_EXTENSION_NAME=vector
OFFERSTEADY_ACCESS_TOKEN_SECRET=replace-me-with-long-random-secret
OFFERSTEADY_ACCESS_TOKEN_EXPIRE_MINUTES=30
OFFERSTEADY_AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
OFFERSTEADY_AUTH_WECHAT_PROVIDER_MODE=compatible
OFFERSTEADY_AUTH_WECHAT_APP_ID=wx-demo-app-id
OFFERSTEADY_AUTH_WECHAT_APP_SECRET=
OFFERSTEADY_AUTH_WECHAT_CALLBACK_URL=http://127.0.0.1:8000/api/v1/auth/wechat/callback
OFFERSTEADY_AUTH_WECHAT_AUTHORIZATION_TTL_SECONDS=300
OFFERSTEADY_AUTH_SMS_PROVIDER_MODE=fake
OFFERSTEADY_AUTH_SMS_ALIYUN_ENDPOINT=https://dypnsapi.aliyuncs.com
OFFERSTEADY_AUTH_SMS_ALIYUN_REGION_ID=cn-hangzhou
OFFERSTEADY_AUTH_SMS_ALIYUN_ACCESS_KEY_ID=
OFFERSTEADY_AUTH_SMS_ALIYUN_ACCESS_KEY_SECRET=
# Personal developers use the system-granted sign name and standard template
# from Aliyun Phone Number Verification Service, not an enterprise custom SMS template.
OFFERSTEADY_AUTH_SMS_ALIYUN_SIGN_NAME=
OFFERSTEADY_AUTH_SMS_ALIYUN_TEMPLATE_CODE=
OFFERSTEADY_AUTH_SMS_TTL_SECONDS=300
OFFERSTEADY_AUTH_SMS_SEND_INTERVAL_SECONDS=30
OFFERSTEADY_AUTH_SMS_DAILY_LIMIT=20
OFFERSTEADY_AUTH_SMS_VERIFY_ATTEMPT_LIMIT=5
OFFERSTEADY_AUTH_SMS_FAKE_CODE=123456
OFFERSTEADY_AUTH_SMS_TEST_PHONE_NUMBER=

# Aliyun OSS
OFFERSTEADY_OSS_BUCKET=offersteady-materials
OFFERSTEADY_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OFFERSTEADY_OSS_REGION=cn-hangzhou
OFFERSTEADY_OSS_KEY_PREFIX=materials
OFFERSTEADY_OSS_ENVIRONMENT_LABEL=development
OFFERSTEADY_OSS_ACCESS_KEY_ID=replace-me
OFFERSTEADY_OSS_ACCESS_KEY_SECRET=replace-me
OFFERSTEADY_OSS_UPLOAD_INTENT_TTL_SECONDS=900
OFFERSTEADY_DESKTOP_RELEASE_DOWNLOAD_TTL_SECONDS=600

# Commercial material storage and indexing
OFFERSTEADY_MATERIAL_MAX_FILE_SIZE_BYTES=52428800
OFFERSTEADY_MATERIAL_MAX_PAGE_COUNT=50
OFFERSTEADY_MATERIAL_MAX_TEXT_CHARACTERS=500000
OFFERSTEADY_MATERIAL_SUPPORTED_EXTENSIONS=[".pdf",".docx",".doc",".txt",".md"]
OFFERSTEADY_MATERIAL_PROCESSING_TIMEOUT_SECONDS=300
OFFERSTEADY_MATERIAL_INDEXING_TIMEOUT_SECONDS=300
OFFERSTEADY_MATERIAL_DELETION_GRACE_SECONDS=0
OFFERSTEADY_MATERIAL_OBJECT_ID_BYTES=16
OFFERSTEADY_MATERIAL_USER_HASH_SALT=replace-me-with-server-only-random-salt

# Third-party integration verification
OFFERSTEADY_INTEGRATION_ENVIRONMENT_LABEL=local
OFFERSTEADY_INTEGRATION_REPORT_OUTPUT_DIR=artifacts/integration-reports
OFFERSTEADY_INTEGRATION_HTTP_TIMEOUT_SECONDS=20
OFFERSTEADY_INTEGRATION_RETRY_ATTEMPTS=1
OFFERSTEADY_INTEGRATION_REALTIME_ASR_PROTOCOL=openai-compatible

# MinerU parser verification
OFFERSTEADY_INTEGRATION_MINERU_BASE_URL=
OFFERSTEADY_INTEGRATION_MINERU_API_KEY=
OFFERSTEADY_INTEGRATION_MINERU_PARSE_PATH=/parse
OFFERSTEADY_INTEGRATION_MINERU_MARKDOWN_FIELD=data.markdown

# Qwen-compatible chat verification
OFFERSTEADY_CHAT_QWEN_BASE_URL=
OFFERSTEADY_CHAT_QWEN_API_KEY=
OFFERSTEADY_CHAT_QWEN_MODEL=deepseek-v4-flash

# Qwen-compatible vision verification
OFFERSTEADY_SCREENSHOT_VISION_BASE_URL=
OFFERSTEADY_SCREENSHOT_VISION_API_KEY=
OFFERSTEADY_SCREENSHOT_VISION_MODEL=qwen-vl-plus

# Embedding verification
OFFERSTEADY_EMBEDDING_BASE_URL=
OFFERSTEADY_EMBEDDING_API_KEY=
OFFERSTEADY_EMBEDDING_MODEL=text-embedding-v3
OFFERSTEADY_EMBEDDING_DIMENSION=1536

# Rerank verification
OFFERSTEADY_RERANK_BASE_URL=
OFFERSTEADY_RERANK_API_KEY=
OFFERSTEADY_RERANK_MODEL=gte-rerank-v2
OFFERSTEADY_RERANK_API_PATH=/rerank
OFFERSTEADY_RAG_CONTEXT_MAX_CHUNKS=6
OFFERSTEADY_RAG_CONTEXT_MAX_CHARACTERS=6000
OFFERSTEADY_RAG_CONTEXT_ALLOW_FULL_DOCUMENT=false

# Realtime ASR verification
OFFERSTEADY_REALTIME_ASR_BASE_URL=
OFFERSTEADY_REALTIME_ASR_WS_URL=
OFFERSTEADY_REALTIME_ASR_API_KEY=
OFFERSTEADY_REALTIME_ASR_MODEL=qwen-realtime
OFFERSTEADY_REALTIME_ASR_WORKSPACE_ID=
OFFERSTEADY_REALTIME_ASR_WORKSPACE_REGION=cn-beijing
OFFERSTEADY_REALTIME_ASR_TURN_DETECTION_MODE=manual
OFFERSTEADY_REALTIME_ASR_TURN_DETECTION_THRESHOLD=0.2
OFFERSTEADY_REALTIME_ASR_TURN_DETECTION_SILENCE_DURATION_MS=800
OFFERSTEADY_REALTIME_DESKTOP_HEARTBEAT_TTL_SECONDS=15
OFFERSTEADY_REALTIME_WEB_HEARTBEAT_TTL_SECONDS=15

# Web public runtime
VITE_APP_ENV=development
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_PUBLIC_APP_VERSION=0.1.0

# MZFPay checkout
OFFERSTEADY_MZFPAY_BASE_URL=https://pay.mzfpay.com
OFFERSTEADY_MZFPAY_PID=
OFFERSTEADY_MZFPAY_KEY=
OFFERSTEADY_MZFPAY_SUBMIT_PATH=/xpay/epay/submit.php
OFFERSTEADY_MZFPAY_NOTIFY_URL=http://127.0.0.1:8000/api/v1/billing/payment-providers/mzfpay/notify
OFFERSTEADY_MZFPAY_RETURN_URL=http://127.0.0.1:5173/app/billing
OFFERSTEADY_MZFPAY_PAYMENT_TTL_SECONDS=900

# Server-only points redemption codes. Keep real codes out of GitHub.
# JSON object: code -> points. Production codes are globally one-time and persisted in PostgreSQL.
OFFERSTEADY_REDEMPTION_CODE_POINTS={}
# Independent server-only HMAC key used to persist code digests without plaintext codes.
OFFERSTEADY_REDEMPTION_CODE_PEPPER=

